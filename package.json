{
  "name": "@pi-vault/pi-subagents",
  "version": "0.2.1",
  "type": "module",
  "description": "Pi extension for delegating tasks to isolated and specialized subagents",
  "author": "Lanh Hoang <lanhhoang@users.noreply.github.com>",
  "license": "MIT",
  "homepage": "https://github.com/pi-vault/pi-subagents#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pi-vault/pi-subagents.git"
  },
  "bugs": {
    "url": "https://github.com/pi-vault/pi-subagents/issues"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "pi-package",
    "pi-extension",
    "pi-subagents",
    "subagents",
    "agents"
  ],
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "biome lint . && tsc --noEmit && vitest run",
    "pack:dry-run": "pnpm pack --dry-run",
    "release:check": "pnpm check && pnpm run pack:dry-run"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "files": [
    "src",
    "agents",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@earendil-works/pi-tui": "^0.80.3",
    "@types/node": "^26.1.0",
    "typebox": "^1.3.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  }
}
